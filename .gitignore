# ============================
#   IGNORAR NODE_MODULES
# ============================
**/node_modules/

# ============================
#   IGNORAR BUILD / DIST
# ============================
**/dist/
**/build/
**/.vite/
**/coverage/

# ============================
#   ARCHIVOS DE CONFIG / AMBIENTE
# ============================
.env
.env.local
.env.development
.env.production
.env.test

# ============================
#   LOGS Y TEMPORALES
# ============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ============================
#   EDITORES / SISTEMA
# ============================
.DS_Store
Thumbs.db
.vscode/
.idea/

# ============================
#   MISC
# ============================
*.cache
*.tmp
*.sqlite
*.bak

# ============================
#   PDFs o archivos generados
# ============================
**/*.pdf

